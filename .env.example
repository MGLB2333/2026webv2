# Contact form email (Resend) — copy this file to .env.local and fill in.
# .env.local is gitignored; never commit real keys.

# Required: your Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=

# Where contact-form submissions are emailed to.
# Defaults to hello@lightboxtv.com if unset.
CONTACT_TO_EMAIL=hello@lightboxtv.com

# The "from" address. MUST be on a domain you've verified in Resend
# (https://resend.com/domains), e.g. "LightBoxTV <noreply@lightboxtv.com>".
# For quick testing without a verified domain, Resend allows
# "onboarding@resend.dev" but it only delivers to your Resend account email.
CONTACT_FROM_EMAIL="LightBoxTV <noreply@lightboxtv.com>"
